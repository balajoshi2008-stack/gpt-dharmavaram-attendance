rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students collection - public read for PIN lookup
    match /students/{yearSem} {
      allow read: if true;
      allow write: if false;
    }

    // Attendance collection - public read, no web write
    match /attendance/{dateKey} {
      allow read: if true;
      allow write: if true;
    }

    // Subjects, timetable, settings, etc.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Users - for login and password management
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Unit Marks
    match /unitMarks/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Notifications
    match /notifications/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Previous Question Papers
    match /pqpLinks/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Assignments
    match /assignments/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Daily Topics - faculty logbook entries
    match /dailyTopics/{dateKey} {
      allow read: if true;
      allow write: if true;
    }

    // Extra Classes - faculty extra class recordings (working day & holiday)
    match /extraClasses/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Academic Calendar - semester start/end dates
    match /academicCalendar/{docId} {
      allow read: if true;
      allow write: if true;
    }

  }
}
